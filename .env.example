# Supabase — Postgres + Storage CDN
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Ably — choose ONE:
#
#  1) Distribution: point at the XMIT token server. No Ably secret is shipped;
#     the app gets short-lived scoped tokens from the server. (see ./server)
# XMIT_SERVER_URL=https://your-xmit-server.example.com
#
#  2) Local dev: use the Ably API key directly (never ship this in a build).
ABLY_API_KEY=your-ably-api-key
